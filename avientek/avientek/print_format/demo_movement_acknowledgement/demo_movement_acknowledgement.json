 "html": "{% set company_doc = frappe.get_doc('Company', doc.company) %}\n<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<style>\n  body { font-family: Arial, sans-serif; font-size: 12px; color: #1a1a1a; margin: 0; padding: 0; }\n  .ack-wrapper { max-width: 800px; margin: 0 auto; padding: 32px; }\n  .ack-header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #1a3a6b; padding-bottom: 16px; margin-bottom: 24px; }\n  .ack-logo img { max-height: 60px; }\n  .ack-company { text-align: right; }\n  .ack-company h3 { margin: 0; font-size: 14px; color: #1a3a6b; }\n  .ack-company p { margin: 2px 0; font-size: 11px; color: #555; }\n  .ack-title { text-align: center; margin-bottom: 24px; }\n  .ack-title h2 { font-size: 18px; color: #1a3a6b; margin: 0; text-transform: uppercase; letter-spacing: 1px; }\n  .ack-title p { margin: 4px 0 0; font-size: 11px; color: #888; }\n  .ack-meta { display: flex; gap: 32px; margin-bottom: 24px; background: #f7f9fc; border-radius: 6px; padding: 14px 20px; }\n  .ack-meta-group { flex: 1; }\n  .ack-meta-group label { font-size: 10px; font-weight: 700; text-transform: uppercase; color: #888; display: block; margin-bottom: 2px; }\n  .ack-meta-group span { font-size: 13px; font-weight: 600; color: #1a1a1a; }\n  .section-title { font-size: 11px; font-weight: 700; text-transform: uppercase; color: #1a3a6b; letter-spacing: 0.5px; border-bottom: 1px solid #dce4f0; padding-bottom: 4px; margin: 20px 0 10px; }\n  table.ack-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }\n  table.ack-table th { background: #1a3a6b; color: #fff; padding: 8px 12px; font-size: 11px; text-align: left; }\n  table.ack-table td { padding: 8px 12px; font-size: 12px; border-bottom: 1px solid #eef1f6; vertical-align: top; }\n  table.ack-table tr:last-child td { border-bottom: none; }\n  .two-col { display: flex; gap: 24px; margin-bottom: 20px; }\n  .two-col .col { flex: 1; }\n  .field-row { margin-bottom: 8px; }\n  .field-row label { font-size: 10px; font-weight: 700; text-transform: uppercase; color: #888; display: block; }\n  .field-row span { font-size: 12px; color: #1a1a1a; }\n  .sig-section { display: flex; gap: 40px; margin-top: 40px; }\n  .sig-box { flex: 1; border-top: 1px solid #333; padding-top: 8px; }\n  .sig-box p { margin: 2px 0; font-size: 11px; color: #555; }\n  .footer-note { margin-top: 32px; padding: 12px 16px; background: #fffbeb; border-left: 3px solid #f59e0b; font-size: 11px; color: #78350f; border-radius: 0 4px 4px 0; }\n  .doc-ref { font-size: 11px; color: #888; text-align: right; margin-bottom: 8px; }\n</style>\n</head>\n<body>\n<div class=\"ack-wrapper\">\n\n  <!-- Header -->\n  <div class=\"ack-header\">\n    <div class=\"ack-logo\">\n      {% if company_doc.company_logo %}\n      <img src=\"{{ company_doc.company_logo }}\">\n      {% else %}\n      <h3 style=\"color:#1a3a6b;margin:0\">{{ doc.company }}</h3>\n      {% endif %}\n    </div>\n    <div class=\"ack-company\">\n      <h3>{{ doc.company }}</h3>\n      {% if company_doc.address %}<p>{{ company_doc.address }}</p>{% endif %}\n      {% if company_doc.phone_no %}<p>Tel: {{ company_doc.phone_no }}</p>{% endif %}\n      {% if company_doc.email %}<p>{{ company_doc.email }}</p>{% endif %}\n    </div>\n  </div>\n\n  <!-- Title -->\n  <div class=\"ack-title\">\n    <h2>Demo Unit Acknowledgement</h2>\n    <p>This document confirms the handover of demonstration equipment to the recipient named below.</p>\n  </div>\n\n  <!-- Doc ref -->\n  <div class=\"doc-ref\">Ref: {{ doc.name }} &nbsp;|&nbsp; Date: {{ frappe.format(doc.movement_date, 'Date') }}</div>\n\n  <!-- Meta strip -->\n  <div class=\"ack-meta\">\n    <div class=\"ack-meta-group\">\n      <label>Customer / Recipient</label>\n      <span>{{ doc.customer or '\u2014' }}</span>\n    </div>\n    <div class=\"ack-meta-group\">\n      <label>Contact Person</label>\n      <span>{{ doc.contact_person or '\u2014' }}</span>\n    </div>\n    <div class=\"ack-meta-group\">\n      <label>Country</label>\n      <span>{{ doc.country or '\u2014' }}</span>\n    </div>\n    <div class=\"ack-meta-group\">\n      <label>Purpose</label>\n      <span>{{ doc.purpose or '\u2014' }}</span>\n    </div>\n  </div>\n\n  <!-- Asset Details -->\n  <div class=\"section-title\">Demo Unit Details</div>\n  {% set asset = frappe.get_doc('Asset', doc.asset) %}\n  {% set item_brand = frappe.db.get_value('Item', asset.item_code, 'brand') or '' %}\n  <table class=\"ack-table\">\n    <thead>\n      <tr>\n        <th>Brand</th>\n        <th>Asset Name</th>\n        <th>Item Code</th>\n        <th>Serial Number</th>\n        <th>Asset ID</th>\n      </tr>\n    </thead>\n    <tbody>\n      <tr>\n        <td>{{ item_brand or '\u2014' }}</td>\n        <td>{{ asset.asset_name or '\u2014' }}</td>\n        <td>{{ asset.item_code or '\u2014' }}</td>\n        <td><b>{{ doc.serial_number or '\u2014' }}</b></td>\n        <td>{{ doc.asset }}</td>\n      </tr>\n    </tbody>\n  </table>\n\n  <!-- Movement Dates -->\n  <div class=\"section-title\">Movement Information</div>\n  <div class=\"two-col\">\n    <div class=\"col\">\n      <div class=\"field-row\">\n        <label>Move Out Date</label>\n        <span>{{ frappe.format(doc.movement_date, 'Date') }}</span>\n      </div>\n      <div class=\"field-row\">\n        <label>Expected Return Date</label>\n        <span>{% if doc.expected_return_date %}{{ frappe.format(doc.expected_return_date, 'Date') }}{% else %}\u2014{% endif %}</span>\n      </div>\n    </div>\n    <div class=\"col\">\n      <div class=\"field-row\">\n        <label>Salesperson</label>\n        <span>{{ doc.requested_salesperson or '\u2014' }}</span>\n      </div>\n      <div class=\"field-row\">\n        <label>Mobile</label>\n        <span>{{ doc.mobile or '\u2014' }}</span>\n      </div>\n    </div>\n  </div>\n\n  {% if doc.notes %}\n  <div class=\"section-title\">Notes</div>\n  <p style=\"font-size:12px; color:#333; margin:0 0 20px\">{{ doc.notes }}</p>\n  {% endif %}\n\n  <!-- Terms -->\n  <div class=\"section-title\">Terms &amp; Conditions</div>\n  <ol style=\"font-size:11px; color:#444; line-height:1.7; padding-left:18px; margin:0 0 20px\">\n    <li>The demo unit remains the property of <b>{{ doc.company }}</b> at all times.</li>\n    <li>The recipient is responsible for the safekeeping of the unit during the demo period.</li>\n    <li>The unit must be returned in the same condition as received by the expected return date.</li>\n    <li>Any damage or loss must be reported to {{ doc.company }} immediately.</li>\n    <li>Unauthorized modification or transfer of the unit is strictly prohibited.</li>\n  </ol>\n\n  <!-- Signatures -->\n  <div class=\"sig-section\">\n    <div class=\"sig-box\">\n      <p><b>Authorized by ({{ doc.company }})</b></p>\n      <p>Name: ______________________________</p>\n      <p>Signature: __________________________</p>\n      <p>Date: ______________________________</p>\n    </div>\n    <div class=\"sig-box\">\n      <p><b>Received by ({{ doc.customer }})</b></p>\n      <p>Name: ______________________________</p>\n      <p>Signature: __________________________</p>\n      <p>Stamp &amp; Date: _____________________</p>\n    </div>\n  </div>\n\n  <!-- Footer note -->\n  <div class=\"footer-note\">\n    \u26a0 <b>Important:</b> This is an acknowledgement of demo loan only. No transfer of ownership is implied.\n    Values, depreciation, and internal financial data are not disclosed in this document.\n  </div>\n\n</div>\n</body>\n</html>",
